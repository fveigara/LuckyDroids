<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="Lucky Droids"/>

    <!-- JUEGO -->
    <LinearLayout
        android:id="@+id/mainActivityRl"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- SLOTS -->
        <LinearLayout
            android:id="@+id/mainActivityLL"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:padding="16dp">

            <ImageView
                android:id="@+id/mainActivitySlot1"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/mainActivitySlot2"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/mainActivitySlot3"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- GANANCIAS -->
        <TextView
            android:id="@+id/mainActivityTvGanancias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ganancias: 10"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

    </LinearLayout>

    <!-- BOTÓN JUGAR -->
    <Button
        android:id="@+id/mainActivityBtJugar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="JUGAR"
        android:textSize="18sp"
        android:layout_margin="16dp" />

</LinearLayout>